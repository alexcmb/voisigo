# Copiez en .env et remplissez les valeurs
# Sur Railway, configurez ces variables dans le dashboard

# Clé secrète JWT — générez une chaîne aléatoire longue
JWT_SECRET=CHANGEZ_MOI_EN_PROD

# Origines frontend autorisées (séparées par des virgules)
# Ex: https://voisigo.vercel.app,https://voisigo-git-main-alexcmb.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Port (Railway l'injecte automatiquement, ne pas modifier)
# PORT=3000
